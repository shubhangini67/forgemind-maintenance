# Hybrid: Docker infra running, backend executed on host machine
# Use after: docker compose up -d postgres qdrant redis

APP_NAME=SteelPlant Maintenance Wizard
APP_ENV=development
DEBUG=true
SECRET_KEY=dev-secret-key
API_PREFIX=/api/v1

DATABASE_URL=postgresql+asyncpg://spmw:spmw_secret@localhost:5432/steelplant_maintenance
DATABASE_URL_SYNC=postgresql://spmw:spmw_secret@localhost:5432/steelplant_maintenance

REDIS_URL=redis://localhost:6379/0

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=maintenance_knowledge
VECTOR_STORE_MODE=qdrant

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
LLM_PROVIDER=gemini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384

JWT_SECRET_KEY=dev-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

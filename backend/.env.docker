# =============================================================================
# Docker / Production — Postgres + Qdrant + Gemini
# Used when running: docker compose --profile full up
# Or copy to backend/.env when using Docker infra locally:
#   cp backend/.env.docker backend/.env
# =============================================================================

APP_NAME=SteelPlant Maintenance Wizard
APP_ENV=production
DEBUG=false
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
API_PREFIX=/api/v1

# PostgreSQL (Docker service name "postgres" inside compose network)
DATABASE_URL=postgresql+asyncpg://spmw:spmw_secret@postgres:5432/steelplant_maintenance
DATABASE_URL_SYNC=postgresql://spmw:spmw_secret@postgres:5432/steelplant_maintenance

# Redis
REDIS_URL=redis://redis:6379/0

# Qdrant vector database
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=maintenance_knowledge
VECTOR_STORE_MODE=qdrant

# Gemini LLM — set GEMINI_API_KEY in project root .env or export before docker compose up
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
LLM_PROVIDER=gemini
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# Embeddings
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384
DATA_DIR=/app/data

# JWT
JWT_SECRET_KEY=change-me-jwt-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

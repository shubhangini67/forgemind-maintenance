# =============================================================================
# SteelPlant Maintenance Wizard — Environment Configuration
# =============================================================================
#
# TWO DEPLOYMENT MODES:
#
# 1. LOCAL (no Docker) — quick hackathon dev
#    cp backend/.env.local backend/.env
#    cd backend && uvicorn app.main:app --reload
#
# 2. DOCKER PRODUCTION — Postgres + Qdrant + Gemini
#    Add GEMINI_API_KEY to this file (project root)
#    docker compose --profile full up --build
#
# 3. HYBRID — Docker infra, backend runs locally
#    docker compose up -d postgres qdrant redis
#    cp backend/.env.docker.hybrid backend/.env
#    (edit DATABASE_URL/QDRANT_URL to use localhost instead of service names)
#
# =============================================================================

# --- Gemini LLM (required for smart responses in production) ---
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.0-flash

# --- Groq fallback (free tier — get key: https://console.groq.com) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Local SQLite mode ---
# DATABASE_URL=sqlite+aiosqlite:///./data/spmw.db
# VECTOR_STORE_MODE=auto
# LLM_PROVIDER=rule_based

# --- Docker Postgres mode ---
# DATABASE_URL=postgresql+asyncpg://spmw:spmw_secret@localhost:5432/steelplant_maintenance
# QDRANT_URL=http://localhost:6333
# VECTOR_STORE_MODE=qdrant

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
